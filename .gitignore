# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# stale root-level db artifact (canonical db is prisma/dev.db)
/dev.db

.omc

# working data JSON files (agent workspace output)
/_workspace/

# SWC build cache
/.swc/

# SQLite database files
# NOTE: prisma/dev.db is intentionally tracked so it can be transferred between machines.
/prisma/test.db

# temporary mockups/scratch files
/scratch/
